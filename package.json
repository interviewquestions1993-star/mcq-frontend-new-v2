{
  "name": "mcq-exam-preparer",
  "version": "1.0.0",
  "description": "AI-powered MCQ exam preparation platform for students and professionals",
  "keywords": [
    "MCQ",
    "exam preparation",
    "AI quiz",
    "interview practice",
    "educational platform",
    "online learning"
  ],
  "author": "MCQ Exam & Interview Preparer",
  "homepage": "https://www.ai-mcq-trainer.in",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "build:seo": "ng build --configuration production --optimization=true --build-optimizer=true",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "seo-check": "echo 'SEO optimizations applied successfully'",
    "deploy": "ng build --configuration production --base-href /mcq-exam-frontend-new-v1/ && npx angular-cli-ghpages --dir=dist/mcq-exam-preparer",
    "deploy:seo": "npm run build:seo -- --base-href /mcq-exam-frontend-new-v1/ && npx angular-cli-ghpages --dir=dist/mcq-exam-preparer"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/material": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@react-oauth/google": "^0.12.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@types/node": "^20.0.0",
    "typescript": "~5.6.0"
  }
}
